COMPOSE_PROJECT_NAME=survey-app

APP_PORT=8080
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=survey_db
POSTGRES_USER=survey_user
POSTGRES_PASSWORD=change-me-postgres-password

DATABASE_URL=postgresql+psycopg://survey_user:change-me-postgres-password@postgres:5432/survey_db
SQLALCHEMY_ECHO=false

JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=survey-app
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
BACKEND_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_API_BASE_URL=/api

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-password
MINIO_BUCKET=avatars
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

WEATHER_API_KEY=
WEATHER_CITY=Moscow
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
WEATHER_TIMEOUT_SECONDS=4
WEATHER_MAX_RETRIES=2
WEATHER_RETRY_BACKOFF_SECONDS=0.3
WEATHER_CACHE_TTL_SECONDS=180
WEATHER_RATE_LIMIT_PER_MIN=30
